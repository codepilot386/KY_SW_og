        <script>
            const BACKEND_URL = window.location.origin;
            let selectedType = "기관 사칭형";
            let myRadarChart = null;
            let currentTurn = 1;
            let lastScammerMessage = "";
            
            // 타이머 전역 변수
            let timerInterval = null;
            let timeRemaining = 15;

            function showScreen(screenId) {
                document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
                document.getElementById(screenId).classList.add('active');
                document.getElementById('wrong-feedback').style.display = 'none';
                if (screenId !== 'screen-training') clearInterval(timerInterval);
            }

            function selectType(element, typeName) {
                document.querySelectorAll('.type-card').forEach(c => c.classList.remove('selected'));
                element.classList.add('selected');
                selectedType = typeName;
            }

            // 타이머 시작 함수
            function startTimer() {
                clearInterval(timerInterval);
                timeRemaining = 15;
                const barFill = document.getElementById('timer-bar-fill');
                const timerText = document.getElementById('phone-timer-text');
                
                barFill.style.width = '100%';
                timerText.innerText = `남은 시간: ${timeRemaining}초`;
                timerText.style.color = 'var(--text-color)';

                timerInterval = setInterval(() => {
                    timeRemaining--;
                    timerText.innerText = `남은 시간: ${timeRemaining}초`;
                    
                    // 비율 계산 및 바 애니메이션 감소
                    let percentage = (timeRemaining / 15) * 100;
                    barFill.style.width = `${percentage}%`;

                    if (timeRemaining <= 5) {
                        timerText.style.color = 'var(--danger-color)';
                    }

                    if (timeRemaining <= 0) {
                        clearInterval(timerInterval);
                        handleTimeOut(); // 시간 초과 처리
                    }
                }, 1000);
            }

            // 시간 초과 시 자동 오답 패널티 처리
            function handleTimeOut() {
                handleOptionClick(
                    "시간 초과(아무 대답도 못 함)", 
                    false, 
                    "⏳ 시간 초과 패널티 발생! 사기꾼이 극도로 긴급하게 압박하자 심리적으로 얼어붙어 적절한 차단 타이밍을 놓쳤습니다. 실전에서는 무대응도 위험할 수 있으니 즉시 끊어야 합니다."
                );
            }

            async function startTraining() {
                currentTurn = 1;
                document.getElementById('current-type-text').innerText = selectedType;
                
                const avatar = document.getElementById('phone-avatar-icon');
                const sender = document.getElementById('phone-sender-title');
                if(selectedType === "기관 사칭형") { avatar.innerText="🏛️"; sender.innerText="[지검] 수사관"; }
                else if(selectedType === "지인 사칭형") { avatar.innerText="💬"; sender.innerText="딸(메신저)"; }
                else { avatar.innerText="💵"; sender.innerText="[국민지원] 김팀장"; }

                showScreen('screen-training');
                document.getElementById('scammer-chat-text').style.display = 'none';
                document.getElementById('quiz-options-container').innerHTML = '';
                document.getElementById('api-loading').style.display = 'block';
                document.getElementById('turn-display').innerText = `${currentTurn} / 10 턴`;

                try {
                    const response = await fetch(`${BACKEND_URL}/api/start`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ training_type: selectedType })
                    });
                    const data = await response.json();
                    renderQuizLayout(data);
                } catch (error) {
                    console.error(error);
                    document.getElementById('scammer-chat-text').innerText = "서버 접속 장애가 발생했습니다.";
                    document.getElementById('scammer-chat-text').style.display = 'block';
                }
            }

            function renderQuizLayout(data) {
                document.getElementById('api-loading').style.display = 'none';
                if (data.is_finished) {
                    clearInterval(timerInterval);
                    showFinalReport(data.report);
                    return;
                }
                lastScammerMessage = data.scammer_message;
                const chatBox = document.getElementById('scammer-chat-text');
                chatBox.innerText = lastScammerMessage;
                chatBox.style.display = 'block';

                const container = document.getElementById('quiz-options-container');
                container.innerHTML = '';
                const pfx = ['가', '나', '다', '라'];
                data.options.forEach((opt, idx) => {
                    const btn = document.createElement('button');
                    btn.className = 'option-btn';
                    btn.innerHTML = `<span>${pfx[idx]}</span> ${opt.text}`;
                    btn.onclick = () => {
                        clearInterval(timerInterval); // 클릭 순간 타이머 멈춤
                        handleOptionClick(opt.text, opt.is_correct, opt.feedback);
                    };
                    container.appendChild(btn);
                });

                // 문제 레이아웃 렌더링 직후 타이머 리셋 및 재시작
                startTimer();
            }

            function handleOptionClick(userText, isCorrect, feedbackText) {
                const overlay = document.getElementById('wrong-feedback');
                const title = document.getElementById('feedback-title');
                const txt = document.getElementById('feedback-text');

                overlay.className = isCorrect ? 'feedback-overlay correct' : 'feedback-overlay';
                title.innerText = isCorrect ? "✅ 안전하고 올바른 대처!" : "🚨 피싱 함정에 도달했습니다!";
                txt.innerText = feedbackText;
                overlay.style.display = 'block';
                overlay.dataset.userResponse = userText;
            }

            async function closeFeedbackAndNext() {
                const overlay = document.getElementById('wrong-feedback');
                const userResponse = overlay.dataset.userResponse;
                overlay.style.display = 'none';

                currentTurn++;
                document.getElementById('turn-display').innerText = `${currentTurn} / 10 턴`;
                document.getElementById('scammer-chat-text').style.display = 'none';
                document.getElementById('quiz-options-container').innerHTML = '';
                document.getElementById('api-loading').style.display = 'block';

                try {
                    const response = await fetch(`${BACKEND_URL}/api/chat`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            training_type: selectedType,
                            previous_message: lastScammerMessage,
                            user_response: userResponse,
                            turn_count: currentTurn
                        })
                    });
                    const data = await response.json();
                    renderQuizLayout(data);
                } catch (error) {
                    console.error(error);
                }
            }

            function showFinalReport(report) {
                showScreen('screen-result');
                document.getElementById('result-score').innerText = `${report.score}점`;
                document.getElementById('result-grade').innerText = report.grade;
                document.getElementById('result-feedback').innerText = report.feedback;
                document.getElementById('result-tips').innerText = report.tip;

                const list = document.getElementById('main-history-list');
                const li = document.createElement('li');
                li.className = 'history-item';
                li.innerHTML = `<span>${selectedType} 실전 훈련</span><span class="score-badge ${report.score >= 80 ? 'score-high':'score-low'}">${report.score}점</span>`;
                list.prepend(li);

                renderChart(report.chart_data);
            }

            function renderChart(chartData) {
                const ctx = document.getElementById('radarChart').getContext('2d');
                if (myRadarChart !== null) myRadarChart.destroy();
                myRadarChart = new Chart(ctx, {
                    type: 'radar',
                    data: {
                        labels: ['기관 사칭', '금융 이익', '지인 사칭', '링크 차단', '위기 대처'],
                        datasets: [{
                            data: chartData || [80, 60, 70, 50, 90],
                            backgroundColor: 'rgba(37, 99, 235, 0.2)',
                            borderColor: '#2563eb',
                            borderWidth: 2,
                            pointBackgroundColor: '#f59e0b',
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: { r: { grid: { color: '#334155' }, angleLines: { color: '#334155' }, pointLabels: { color: '#94a3b8' }, ticks: { display: false }, suggestedMin: 0, suggestedMax: 100 } },
                        plugins: { legend: { display: false } }
                    }
                });
            }
        </script>
    </body>
    </html>
    """

