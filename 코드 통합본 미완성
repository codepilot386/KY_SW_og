@app.post("/api/start")
async def start_training(req: StartRequest):
    try:
        # 프롬프트 간소화 및 길이 제약 조건을 강화하여 연산 속도를 비약적으로 단축
        prompt = f"""
        너는 [{req.training_type}] 보이스피싱 사기꾼이야. 
        타겟(사용자)을 당황하게 만들 첫 압박 대사를 시작해.
        
        [🚨 아주 중요 지침]
        1. 사기꾼 대사(scammer_message)는 반드시 최대 '2문장 이내'로 짧고 명확하게 압박해. 길면 절대 안 돼!
        2. 선택지(options) 4개 역시 모바일 화면에 맞게 한 줄 짜리로 콤팩트하게 작성해.
        - 오답(false): 유저가 당황해 속아 넘어가는 치명적 실수 행동.
        - 정답(true): 통화를 끊거나 직접 공식 기관으로 교차 검증을 선언하는 안전한 행동.
        
        반드시 마크다운 기호 없이 순수 다음 JSON 형식으로만 짧게 응답해:
        {{
          "scammer_message": "2문장 이내의 핵심 사기 압박 멘트",
          "options": [
            {{ "id": 1, "text": "짧은 선택지 1", "is_correct": true, "feedback": "훌륭한 대처 수칙입니다." }},
            {{ "id": 2, "text": "짧은 함정 선택지 2", "is_correct": false, "feedback": "사기꾼의 압박 페이스에 말려든 행동입니다." }},
            {{ "id": 3, "text": "짧은 함정 선택지 3", "is_correct": false, "feedback": "주의하십시오. 피싱 유도에 취약합니다." }},
            {{ "id": 4, "text": "짧은 함정 선택지 4", "is_correct": false, "feedback": "위험한 판단입니다." }}
          ]
        }}
        """
        response = await model.generate_content_async(
            prompt, 
            generation_config={"response_mime_type": "application/json"},
            safety_settings=safety_settings
        )
        return json.loads(response.text)
    except Exception as e:
        return {"error": str(e)}

@app.post("/api/chat")
async def continue_training(req: ChatRequest):
    try:
        is_last_turn = req.turn_count >= 10
        if is_last_turn:
            prompt = f"""
            [{req.training_type}] 보이스피싱 대응 훈련이 최종 종료되었습니다.
            사용자가 마지막 단계에서 택한 대처 행동은 "{req.user_response}" 입니다.
            대화 맥락을 요약하여 종합 성적 리포트를 JSON으로 반환해줘.
            
            반드시 다음 JSON 포맷으로 응답해:
            {{
              "scammer_message": "훈련이 종료되었습니다.",
              "is_finished": true,
              "report": {{
                "score": 0~100사이 정수,
                "grade": "등급 결과 명칭",
                "feedback": "핵심 취약점 위주의 간결한 요약 총평",
                "tip": "실전 예방 핵심 행동 강령 수칙 2가지",
                "chart_data": [85, 65, 70, 60, 75]
              }}
            }}
            """
        else:
            prompt = f"""
            너는 [{req.training_type}] 보이스피싱 사기꾼이야.
            이전 대사: "{req.previous_message}"
            유저의 대응: "{req.user_response}"
            
            유저의 대응을 받아치며 긴급하게 신분 불이익이나 송금을 가스라이팅하는 대사를 이어가되, 다음 조건을 무조건 지켜줘.
            
            [🚨 아주 중요 지침]
            1. 사기꾼 대사(scammer_message)는 무조건 '2문장 이내'로 핵심만 짤막하게 던져. 긴 장문은 절대 엄금!
            2. 선택지들도 가독성 좋게 한 줄짜리로 짧게 생성해.
            
            반드시 다음 JSON 형식으로만 답변해:
            {{
              "scammer_message": "2문장 이내의 아주 짧은 사기꾼 대사",
              "is_finished": false,
              "options": [
                {{ "id": 1, "text": "짧은 대처 1", "is_correct": false, "feedback": "피드백 문구" }},
                {{ "id": 2, "text": "짧은 대처 2", "is_correct": true, "feedback": "안전한 대처 방식입니다." }},
                {{ "id": 3, "text": "짧은 대처 3", "is_correct": false, "feedback": "피드백 문구" }},
                {{ "id": 4, "text": "짧은 대처 4", "is_correct": false, "feedback": "피드백 문구" }}
              ]
            }}
            """
        response = await model.generate_content_async(
            prompt, 
            generation_config={"response_mime_type": "application/json"},
            safety_settings=safety_settings
        )
        return json.loads(response.text)
    except Exception as e:
        return {"error": str(e)}
